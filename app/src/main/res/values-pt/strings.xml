    <string name="settings_voice_system_settings">Definições de voz do sistema</string>
    <string name="settings_voice_test_hint">Toque em Testar voz para a ouvir. Recomenda-se a voz Vela; pode optar por qualquer motor de texto para voz instalado.</string>
