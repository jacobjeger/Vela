    <string name="settings_routing_size">%1$s MB</string>
    <string name="settings_routing_remove">Remover percursos offline</string>
    <string name="settings_download">Transferir</string>
    <string name="settings_saved_places">Locais guardados</string>
    <string name="settings_saved_places_hint">Faça uma cópia de segurança dos locais marcados com estrela num ficheiro ou restaure-os noutro dispositivo. A importação junta ao que já tem — nunca substitui nem remove nada.</string>
    <string name="settings_import_nothing">Nada de novo para importar</string>
    <string name="settings_no_saved_places">Ainda sem locais guardados</string>
    <string name="settings_export">Exportar</string>
    <string name="settings_import">Importar</string>
    <string name="settings_data_privacy">Fonte de dados e privacidade</string>
    <string name="settings_data_privacy_hint">O Vela comunica diretamente com os pontos de acesso web públicos da Google a partir deste dispositivo — sem servidor Vela, sem conta Google, sem chave de API e sem telemetria, a menos que ative o Diagnóstico abaixo (desligado por predefinição, apenas local). Cada dispositivo comporta-se como um navegador sem sessão iniciada; a Google vê o seu IP, pesquisa e área do mapa, mas não uma conta. Os locais guardados e o histórico nunca saem do telemóvel.</string>
    <string name="settings_privacy_button">Que dados a Google recebe</string>
    <string name="settings_diagnostics">Diagnóstico</string>
    <string name="settings_diagnostics_hint">Desligado por predefinição. Quando ligado, o Vela mantém um breve registo local do que fez — as suas pesquisas, percursos e quaisquer falhas de “necessita recalibração” — para que, se algo se comportar mal, possa exportá-lo e entregá-lo a um programador. Permanece neste telemóvel e nunca é carregado; é você que escolhe para onde vai a exportação. Desligá-lo apaga o registo.</string>
    <string name="settings_share_diagnostics">Partilhar diagnóstico</string>
    <string name="settings_diag_nothing">Ainda nada registado — use a aplicação e depois exporte.</string>
    <string name="settings_diag_export">Exportar sessão de depuração</string>
    <string name="settings_save_trips">Guardar as minhas viagens (para reprodução)</string>
    <string name="settings_save_trips_hint">Regista o traço GPS de cada navegação neste telemóvel para que uma viagem possa ser reproduzida mais tarde e testar a navegação curva a curva sem a percorrer novamente. Mais revelador do que o diagnóstico — são os seus percursos exatos — e nunca sai do telemóvel.</string>
    <string name="settings_recorded_trips_hint">Viagens gravadas — toque em Reproduzir para reproduzir uma no mapa (3×):</string>
    <string name="settings_trip_points">%1$d pontos</string>
    <string name="settings_trip_replay">Reproduzir</string>
    <string name="settings_trip_read_error">Não foi possível ler essa viagem</string>
    <string name="settings_trip_share">Partilhar</string>
    <string name="settings_trip_delete">Eliminar viagem</string>
    <string name="settings_no_trips_hint">Ainda sem viagens gravadas — navegue para algum lado com isto ligado e aparecerá aqui para reproduzir.</string>
    <string name="settings_trip_consent_title">Guardar as suas viagens?</string>
    <string name="settings_trip_consent_body">O Vela vai gravar o traço GPS de cada navegação neste telemóvel, para que uma viagem possa ser reproduzida para testes sem a percorrer novamente. Isto é mais revelador do que o diagnóstico — captura os seus percursos exatos — mas permanece no telemóvel e nunca é carregado. Desligue quando quiser.</string>
    <string name="settings_turn_on">Ativar</string>
    <string name="settings_cancel">Cancelar</string>
    <string name="settings_crash_hint">O Vela fechou-se inesperadamente há pouco. Enviar o relatório de erro (rastreio da pilha) ajuda a corrigi-lo — é um ficheiro de texto simples, sem dados pessoais.</string>
    <string name="settings_crash_export">Exportar relatório de erro</string>
    <string name="settings_crash_discard">Descartar</string>
    <string name="settings_diag_consent_title">Ativar o diagnóstico?</string>
    <string name="settings_diag_consent_body">O Vela vai manter um breve registo local das suas pesquisas, percursos e quaisquer erros. Nunca sai do telemóvel a menos que toque em Exportar e escolha para onde o enviar. Desligue quando quiser para apagar o registo.</string>
    <string name="settings_about">Acerca</string>
    <string name="settings_about_hint">O Vela é um cliente de mapas sem Google: mosaicos abertos para o mapa base, dados da Google recolhidos para POIs, percursos e ETAs sensíveis ao trânsito, e o TextToSpeech do AOSP para a voz. GPLv3. Não requer os Serviços Play.</string>
    <string name="settings_support">Apoiar</string>
    <string name="settings_support_hint">O Vela é gratuito e sem anúncios. Se se tornou útil, um donativo ajuda a manter o desenvolvimento — totalmente opcional.</string>
    <string name="settings_support_button">Apoiar o Vela</string>
