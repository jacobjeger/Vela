    <string name="root_diag_title">Ajudar a melhorar o Vela?</string>
    <string name="root_diag_body">Ambos permanecem no seu telemóvel — nada é enviado a menos que o exporte. Altere qualquer um a qualquer momento nas Definições.</string>
    <string name="root_diag_share_title">Partilhar diagnóstico</string>
    <string name="root_diag_share_desc">Um breve registo local de pesquisas, percursos e erros.</string>
    <string name="root_diag_trips_title">Guardar as minhas viagens</string>
    <string name="root_diag_trips_desc">Regista os traços GPS de navegação para que as viagens possam ser reproduzidas para testes. Mais revelador — os seus percursos exatos.</string>
    <string name="root_diag_save">Guardar escolhas</string>
