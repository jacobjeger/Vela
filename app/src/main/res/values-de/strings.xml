    <string name="root_diag_share_desc">Ein kurzes lokales Protokoll von Suchanfragen, Routen &amp; Fehlern.</string>
    <string name="root_diag_trips_title">Meine Fahrten speichern</string>
    <string name="root_diag_trips_desc">Zeichnet Ihre GPS-Spuren auf, sodass Fahrten zum Testen wiedergegeben werden können. Aufschlussreicher – Ihre genauen Routen.</string>
