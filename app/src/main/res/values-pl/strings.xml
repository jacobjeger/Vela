    <string name="root_diag_trips_title">Zapisuj moje podróże</string>
    <string name="root_diag_trips_desc">Zapisuje ślady GPS nawigacji, aby przejazdy można było odtworzyć do testów. Bardziej ujawniające — Twoje dokładne trasy.</string>
