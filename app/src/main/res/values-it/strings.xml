    <string name="settings_saved_places">Luoghi salvati</string>
    <string name="settings_saved_places_hint">Esegui il backup dei luoghi preferiti su un file o ripristinali su un altro dispositivo. L\'importazione si unisce a ciò che hai già: non sovrascrive né rimuove nulla.</string>
