    <string name="root_diag_title">Aiutare a migliorare Vela?</string>
    <string name="root_diag_body">Entrambi restano sul telefono: nulla viene inviato finché non lo esporti. Puoi modificarli in qualsiasi momento nelle Impostazioni.</string>
    <string name="root_diag_share_title">Condividi diagnostica</string>
    <string name="root_diag_share_desc">Un breve registro locale di ricerche, percorsi ed errori.</string>
    <string name="root_diag_trips_title">Salva i miei viaggi</string>
    <string name="root_diag_trips_desc">Registra le tracce GPS di navigazione così i tragitti possono essere riprodotti per i test. Più rivelatore: i tuoi percorsi esatti.</string>
