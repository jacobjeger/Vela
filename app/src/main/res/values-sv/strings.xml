    <string name="settings_language">Språk</string>
    <string name="settings_language_hint">Anger språket för talade vägbeskrivningar sväng för sväng (engelska, franska, tyska, spanska, italienska, portugisiska, nederländska, ryska, polska, svenska, ukrainska) – oberoende av telefonens systemspråk. Välj en röst som matchar i Röstbiblioteket nedan. Resten av appens skärmtext översätts härnäst.</string>
    <string name="settings_voice">Röst</string>
    <string name="settings_voice_fallback_name">röst</string>
    <string name="settings_voice_downloading">Hämtar %1$s… %2$d %%</string>
    <string name="settings_voice_none_hint">Ingen röst ännu – öppna Röstbiblioteket nedan för att hämta en naturlig röst på enheten (inget konto, i realtid även på äldre telefoner). En system-TTS-motor som du installerar visas också här att välja.</string>
    <string name="settings_voice_test">Testa rösten</string>
    <string name="settings_voice_system_settings">Systemets röstinställningar</string>
    <string name="settings_voice_test_hint">Tryck på Testa rösten för att höra den. Vela-rösten rekommenderas; du kan byta till valfri installerad text-till-tal-motor.</string>
    <string name="settings_voice_library">Röstbibliotek</string>
    <string name="settings_voice_advanced">Avancerade röstalternativ</string>
