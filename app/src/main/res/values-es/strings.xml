    <string name="settings_saved_places">Lugares guardados</string>
    <string name="settings_saved_places_hint">Haz una copia de seguridad de tus lugares favoritos en un archivo o restáuralos en otro dispositivo. La importación se combina con lo que ya tienes: nunca sobrescribe ni elimina nada.</string>
    <string name="settings_import_nothing">No hay nada nuevo que importar</string>
    <string name="settings_no_saved_places">Aún no hay lugares guardados</string>
    <string name="settings_export">Exportar</string>
    <string name="settings_import">Importar</string>
    <string name="settings_data_privacy">Fuente de datos y privacidad</string>
    <string name="settings_data_privacy_hint">Vela se comunica con los endpoints web públicos de Google directamente desde este dispositivo: sin servidor de Vela, sin cuenta de Google, sin clave de API y sin telemetría, salvo que actives el Diagnóstico de más abajo (desactivado de forma predeterminada, solo local). Cada dispositivo se comporta como un navegador sin sesión iniciada; Google ve tu IP, tu consulta y la zona del mapa, pero no una cuenta. Los lugares guardados y el historial nunca salen del teléfono.</string>
    <string name="settings_privacy_button">Qué datos recibe Google</string>
    <string name="settings_diagnostics">Diagnóstico</string>
    <string name="settings_diagnostics_hint">Desactivado de forma predeterminada. Cuando está activado, Vela guarda un breve registro local de lo que hizo (tus búsquedas, rutas y cualquier fallo de «necesita recalibración») para que, si algo va mal, puedas exportarlo y entregárselo a un desarrollador. Permanece en este teléfono y nunca se sube; tú eliges dónde va la exportación. Al desactivarlo se borra el registro.</string>
    <string name="settings_share_diagnostics">Compartir diagnóstico</string>
    <string name="settings_diag_nothing">Aún no hay nada registrado: usa la app y luego exporta.</string>
    <string name="settings_diag_export">Exportar sesión de depuración</string>
    <string name="settings_save_trips">Guardar mis trayectos (para reproducir)</string>
    <string name="settings_save_trips_hint">Registra el rastro GPS de cada navegación en este teléfono para que un trayecto pueda reproducirse más tarde y probar la navegación giro a giro sin volver a conducirlo. Revela más que el diagnóstico (son tus rutas exactas) y nunca sale del teléfono.</string>
    <string name="settings_recorded_trips_hint">Trayectos grabados: toca Reproducir para volver a verlo en el mapa (3×):</string>
    <string name="settings_trip_points">%1$d puntos</string>
    <string name="settings_trip_replay">Reproducir</string>
    <string name="settings_trip_read_error">No se pudo leer ese trayecto</string>
    <string name="settings_trip_share">Compartir</string>
    <string name="settings_trip_delete">Eliminar trayecto</string>
    <string name="settings_no_trips_hint">Aún no hay trayectos grabados: navega a algún sitio con esto activado y aparecerá aquí para reproducirlo.</string>
    <string name="settings_trip_consent_title">¿Guardar tus trayectos?</string>
    <string name="settings_trip_consent_body">Vela grabará el rastro GPS de cada navegación en este teléfono, para que un trayecto pueda reproducirse en pruebas sin volver a conducirlo. Esto revela más que el diagnóstico (captura tus rutas exactas), pero permanece en el teléfono y nunca se sube. Puedes desactivarlo cuando quieras.</string>
    <string name="settings_turn_on">Activar</string>
    <string name="settings_cancel">Cancelar</string>
    <string name="settings_crash_hint">Vela se cerró de forma inesperada hace poco. Enviar el informe de fallo (traza de la pila) ayuda a corregirlo: es un archivo de texto plano, sin datos personales.</string>
    <string name="settings_crash_export">Exportar informe de fallo</string>
    <string name="settings_crash_discard">Descartar</string>
    <string name="settings_diag_consent_title">¿Activar el diagnóstico?</string>
    <string name="settings_diag_consent_body">Vela guardará un breve registro local de tus búsquedas, rutas y cualquier error. Nunca sale del teléfono salvo que toques Exportar y elijas a dónde enviarlo. Desactívalo cuando quieras para borrar el registro.</string>
    <string name="settings_about">Acerca de</string>
    <string name="settings_about_hint">Vela es un cliente de mapas sin Google: mosaicos abiertos para el mapa base, datos de Google extraídos para los puntos de interés, rutas y ETA con tráfico, y TextToSpeech de AOSP para la voz. GPLv3. No requiere Play Services.</string>
    <string name="settings_support">Apoyar</string>
    <string name="settings_support_hint">Vela es gratis y sin anuncios. Si te resulta útil, una donación ayuda a mantener el desarrollo en marcha, completamente opcional.</string>
    <string name="settings_support_button">Apoyar a Vela</string>
