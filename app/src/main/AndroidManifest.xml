<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location is AOSP-only (LocationManager); no Play Services needed. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- For the (future) foreground navigation service that keeps guidance
         alive with the screen off. Declared now so the design is explicit. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Haptic turn cues during navigation (normal permission, auto-granted). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- So a phone with NO text-to-speech engine (common on degoogled ROMs) can be
         offered a one-tap install of an open-source voice (eSpeak NG / RHVoice from
         F-Droid). The user still confirms each install in the system dialog. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- GPS strongly preferred but don't hard-exclude tablets/AAOS units. -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <!-- Android 11+ package visibility: without this, TextToSpeech.getEngines()
         returns nothing and the engine can't be bound, so spoken directions are
         silent on a targetSdk-30+ build. Declares we need to see + use TTS engines
         (the dialer/share/map intents resolve via startActivity, no query needed). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".VelaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vela">

        <!-- Hands the downloaded voice-engine APK to the system installer via a
             content:// URI (file:// is blocked for installs on modern Android). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.Vela">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- geo: links from other apps → Vela can be your default maps handler. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="geo" />
            </intent-filter>

            <!-- Google-Maps web links → "open in maps" offers Vela too. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="www.google.com" android:pathPrefix="/maps" />
                <data android:host="google.com" android:pathPrefix="/maps" />
                <data android:host="maps.google.com" />
                <data android:host="maps.app.goo.gl" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.NavigationService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>

</manifest>
